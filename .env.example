# KURUP ADS BOT - Environment Configuration Example

# =============== Bot Tokens (REQUIRED) ===============
# Get from @BotFather
MAIN_BOT_TOKEN=12345678:ABCDEFGHIJKLMNOPQRSTUVWXYZ
LOGIN_BOT_TOKEN=12345678:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# =============== MongoDB (REQUIRED) ===============
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://...

# =============== Admin Settings ===============
OWNER_ID=12345678

# =============== Branding Settings ===============
# These will be enforced across all connected accounts
BRANDING_NAME=‣ Kᴜʀᴜᴘ Aᴅs
BRANDING_BIO=Powered by @KurupAdsBot | Network: @PhiloBots

# =============== Advanced Settings (Optional) ===============
# Bot UI branding details
MAIN_BOT_USERNAME=KurupAdsBot
CHANNEL_USERNAME=PHilobots
REQUIRED_CHANNELS=philobots,sellinghub0,kurupads

# Worker performance
WORKER_CONCURRENCY=10
SESSION_POOL_MAX_SIZE=200

# Rate-limiting (Anti-Freeze)
GROUP_GAP_SECONDS=45
MESSAGE_GAP_SECONDS=219
SEND_DELAY_MIN=10
SEND_DELAY_MAX=200

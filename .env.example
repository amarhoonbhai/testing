# ═══════════════════════════════════════════════════════════════════
# KURUP ADS BOT — Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# ── Bot Token (REQUIRED) — Get from @BotFather ──────────────────
BOT_TOKEN=your_bot_token_here

# ── Telegram API (REQUIRED) — Get from https://my.telegram.org ──
API_ID=12345678
API_HASH=your_api_hash_here

# ── MongoDB (REQUIRED) ─────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/kurup_ads
MONGO_DB_NAME=kurup_ads

# ── Encryption Key (REQUIRED) ──────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# ── Branding ───────────────────────────────────────────────────
BOT_USERNAME=AutoMessageSchedulerBot
SUPPORT_USERNAME=kurupads
CHANNEL_USERNAME=philobots

# ── Enforced Branding (applied to hosted accounts) ─────────────
ENFORCED_NAME=‣ Kᴜʀᴜᴘ Aᴅs
ENFORCED_BIO=Powered by @KurupAdsBot | Network: @PhiloBots

# ── Force Join Channels (comma-separated, no @) ───────────────
REQUIRED_CHANNELS=philobots,sellinghub0

# ── Limits ─────────────────────────────────────────────────────
MAX_ACCOUNTS=5
MIN_INTERVAL=1200          # 20 minutes minimum between cycles

# ── Rate Limiting (Anti-Freeze Protection) ─────────────────────
SEND_GAP_SECONDS=300       # 5 minutes between individual sends
SEND_JITTER_MIN=30         # Random jitter min (seconds)
SEND_JITTER_MAX=90         # Random jitter max (seconds)
FLOOD_BACKOFF_BASE=60      # Exponential backoff base (seconds)
FLOOD_BACKOFF_MAX=3600     # Max backoff cap (1 hour)
MAX_CONSECUTIVE_ERRORS=5   # Auto-pause after N consecutive errors

# ── Night Mode (IST) ──────────────────────────────────────────
NIGHT_MODE_ENABLED=true
NIGHT_MODE_START=0         # 12:00 AM
NIGHT_MODE_END=5           # 5:00 AM
TIMEZONE=Asia/Kolkata

# ── Owner ──────────────────────────────────────────────────────
OWNER_ID=0

# ── Logs Channel (@spinifylogs) ────────────────────────────────
LOGS_CHANNEL_ID=-1003818032027

# ── Banner ─────────────────────────────────────────────────────
BANNER_PATH=assets/banner.png

# Group Message Scheduler - Environment Configuration

# =============== Bot Tokens (REQUIRED) ===============
# Get from @BotFather
MAIN_BOT_TOKEN=12345678:ABCDEFGHIJKLMNOPQRSTUVWXYZ
LOGIN_BOT_TOKEN=12345678:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# =============== Bot Usernames ===============
MAIN_BOT_USERNAME=KurupAdsBot
LOGIN_BOT_USERNAME=Kuruploginbot

# =============== Admin Settings ===============
OWNER_ID=12345678

# =============== MongoDB (REQUIRED) ===============
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/spinify
MONGODB_DB_NAME=spinify

# =============== Channel Settings ===============
CHANNEL_USERNAME=PHilobots
REQUIRED_CHANNELS=philobots,sellinghub0,kurupads

# =============== Worker Performance ===============
WORKER_CONCURRENCY=10
SESSION_POOL_MAX_SIZE=200

# =============== Rate-limit Protection ===============
GROUP_GAP_SECONDS=45
MESSAGE_GAP_SECONDS=210
SEND_DELAY_MIN=10
SEND_DELAY_MAX=20
